#!/usr/bin/env bash
set -e

BTRFS_BIN=$(command -v btrfs)

DEV=$(findmnt -n -o SOURCE / | cut -d'[' -f1)
MNT_ROOT="/run/btrfs_root"

mkdir -p "$MNT_ROOT"
mount -o subvolid=5 "$DEV" "$MNT_ROOT"

umount -l /home || true

"$BTRFS_BIN" subvolume delete "$MNT_ROOT/@"
"$BTRFS_BIN" subvolume snapshot "$MNT_ROOT/@snapshots/@.pure_system" "$MNT_ROOT/@"

"$BTRFS_BIN" subvolume delete "$MNT_ROOT/@home"
"$BTRFS_BIN" subvolume snapshot "$MNT_ROOT/@snapshots/@home.pure_system" "$MNT_ROOT/@home"

grub-mkconfig -o /boot/grub/grub.cfg

echo "Full rollback successful. Reboot your pc!"

