#!/usr/bin/env bash
set -e

MNT_ROOT="/run/mount/btrfs_root"
mkdir -p "$MNT_ROOT"

mount -o subvolid=5 $(findmnt -n -o SOURCE /) "$MNT_ROOT"

umount -l /home || true

btrfs subvolume delete "$MNT_ROOT/@"
btrfs subvolume snapshot "$MNT_ROOT/@snapshots/@.pure_system" "$MNT_ROOT/@"

btrfs subvolume delete "$MNT_ROOT/@home"
btrfs subvolume snapshot "$MNT_ROOT/@snapshots/@home.pure_system" "$MNT_ROOT/@home"

echo "Full rollback successful. Rebooting..."
reboot

